<?xml version="1.0"?>
<data>
    <xpath expr="/form" position="inside">
        <field name="filter_products_by_stock" invisible="1"/>
        <field name="filter_products_by_forecast" invisible="1"/>
        <field name="unordered_product_search" invisible="1"/>
    </xpath>

    <xpath expr="/form/notebook/page[@id='general']/field[@name='unit_price']"
        position="after">
        <label name="quantity_available"/>
        <field name="quantity_available" readonly="1"/>
        <label name="forecast_quantity_available"/>
        <field name="forecast_quantity_available" readonly="1"/>
    </xpath>
</data>
